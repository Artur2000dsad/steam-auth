[Unit]
Description=SABR RUST website + Steam Auth
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/steam-auth/app
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/steam-auth/app/.venv/bin/python main_server.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
